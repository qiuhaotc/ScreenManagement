<Window x:Class="ScreenManagement.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:ScreenManagement.UI.Converters"
        xmlns:vm="clr-namespace:ScreenManagement.UI.ViewModels"
        mc:Ignorable="d"
        Title="Screen Management"
        Icon="app.ico"
        Height="560" Width="720"
        MinHeight="400" MinWidth="560"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackgroundBrush}"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}">

    <Window.Resources>
        <converters:BoolToHdrStatusConverter x:Key="BoolToHdrStatus"/>
        <converters:DisplayModeToIconConverter x:Key="ModeToIcon"/>
        <converters:DisplayModeToNameConverter x:Key="ModeToName"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:NotConverter x:Key="NotConverter"/>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== 状态显示区 ===== -->
        <Border Grid.Row="0" Margin="0,0,0,16"
                Background="{StaticResource CardBackgroundBrush}"
                CornerRadius="8" Padding="20">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding CurrentMode, Converter={StaticResource ModeToIcon}}"
                           FontSize="36" VerticalAlignment="Center" Margin="0,0,16,0"/>
                <StackPanel>
                    <TextBlock Text="当前显示模式" FontSize="12"
                               Foreground="{StaticResource SecondaryTextBrush}"/>
                    <TextBlock Text="{Binding CurrentMode, Converter={StaticResource ModeToName}}"
                               FontSize="22" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                               Foreground="{StaticResource AccentBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>
                <!-- 加载指示器 -->
                <Border CornerRadius="12" Padding="10,4" Margin="16,0,0,0"
                        Background="{StaticResource AccentBrush}" Opacity="0.85"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="切换中..." FontSize="11"
                               Foreground="White"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- ===== 显示器列表 ===== -->
        <Border Grid.Row="1" Margin="0,0,0,16"
                Background="{StaticResource CardBackgroundBrush}"
                CornerRadius="8" Padding="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Displays}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="8,6" Padding="16,12"
                                    Background="{StaticResource ItemBackgroundBrush}"
                                    CornerRadius="6">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Opacity" Value="1"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                <Setter Property="Opacity" Value="0.55"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="🖥" FontSize="28"
                                               VerticalAlignment="Center" Margin="0,0,16,0"/>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding DisplayName}" FontSize="14"
                                                       FontWeight="SemiBold"/>
                                            <Border CornerRadius="4" Padding="4,2" Margin="8,0,0,0"
                                                    Background="{StaticResource TagBackgroundBrush}"
                                                    Visibility="{Binding IsPrimary, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="主显示器" FontSize="10"/>
                                            </Border>
                                            <Border CornerRadius="4" Padding="4,2" Margin="4,0,0,0"
                                                    Background="{StaticResource TagBackgroundBrush}"
                                                    Visibility="{Binding IsInternal, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="内置" FontSize="10"/>
                                            </Border>
                                            <Border CornerRadius="4" Padding="4,2" Margin="4,0,0,0"
                                                    Background="#33888888"
                                                    Visibility="{Binding IsActive, Converter={StaticResource NotConverter}}">
                                                <TextBlock Text="未启用" FontSize="10" Foreground="{StaticResource SecondaryTextBrush}"/>
                                            </Border>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock FontSize="12" Foreground="{StaticResource SecondaryTextBrush}">
                                                <Run Text="HDR:"/>
                                                <Run Text="{Binding HdrEnabled, Converter={StaticResource BoolToHdrStatus}}"
                                                     Foreground="{StaticResource AccentBrush}"/>
                                            </TextBlock>
                                            <TextBlock Text=" | " FontSize="12"
                                                       Foreground="{StaticResource SecondaryTextBrush}"
                                                       Visibility="{Binding IsActive, Converter={StaticResource BoolToVis}}"/>
                                            <TextBlock FontSize="12" Foreground="{StaticResource SecondaryTextBrush}"
                                                       Visibility="{Binding IsActive, Converter={StaticResource BoolToVis}}">
                                                <Run Text="分辨率:"/>
                                                <Run Text="{Binding ResolutionX}"/>
                                                <Run Text="×"/>
                                                <Run Text="{Binding ResolutionY}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Orientation="Horizontal">
                                        <Button Content="切换HDR" Width="80" Height="28" FontSize="11"
                                                Command="{Binding DataContext.ToggleHdrCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                                    <Setter Property="IsEnabled" Value="True"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SupportsHdr}" Value="False">
                                                            <Setter Property="IsEnabled" Value="False"/>
                                                            <Setter Property="Opacity" Value="0.4"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                            <Setter Property="IsEnabled" Value="False"/>
                                                            <Setter Property="Opacity" Value="0.4"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- ===== 快捷操作按钮 ===== -->
        <Border Grid.Row="2" Margin="0,0,0,12"
                Background="{StaticResource CardBackgroundBrush}"
                CornerRadius="8" Padding="16">
            <StackPanel>
                <TextBlock Text="快捷操作" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <UniformGrid Columns="4" HorizontalAlignment="Stretch">
                    <Button Content="&#x1f4fa;&#x0a;仅电脑屏幕" Height="56" Margin="0,0,6,0"
                            Style="{StaticResource ModeButtonStyle}"
                            Command="{Binding SetDisplayModeCommand}"
                            CommandParameter="Internal"/>
                    <Button Content="&#x1f503;&#x0a;复制" Height="56" Margin="3,0"
                            Style="{StaticResource ModeButtonStyle}"
                            Command="{Binding SetDisplayModeCommand}"
                            CommandParameter="Clone"/>
                    <Button Content="&#x1f4fa;&#x1f4fa;&#x0a;扩展" Height="56" Margin="3,0"
                            Style="{StaticResource ModeButtonStyle}"
                            Command="{Binding SetDisplayModeCommand}"
                            CommandParameter="Extend"/>
                    <Button Content="&#x1f5a5;&#x0a;仅第二屏幕" Height="56" Margin="6,0,0,0"
                            Style="{StaticResource ModeButtonStyle}"
                            Command="{Binding SetDisplayModeCommand}"
                            CommandParameter="External"/>
                </UniformGrid>
            </StackPanel>
        </Border>

        <!-- ===== 底部导航 ===== -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 开机自启 -->
            <CheckBox Grid.Column="0" VerticalAlignment="Center"
                      IsChecked="{Binding AutoStartEnabled}"
                      Content="开机自动启动"
                      FontSize="13"/>

            <!-- 链接按钮 -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="⚙ 快捷键设置" Style="{StaticResource LinkButtonStyle}"
                        Margin="0,0,16,0"
                        Command="{Binding OpenHotkeySettingsCommand}"/>
                <Button Content="ℹ 关于" Style="{StaticResource LinkButtonStyle}"
                        Command="{Binding OpenAboutCommand}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
