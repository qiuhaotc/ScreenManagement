<Window x:Class="ScreenManagement.UI.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:ScreenManagement.UI.ViewModels"
        mc:Ignorable="d"
        Title="关于 Screen Management" Height="360" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource WindowBackgroundBrush}"
        d:DataContext="{d:DesignInstance Type=vm:AboutViewModel}">

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 应用图标和名称 -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,20">
            <TextBlock Text="🖥" FontSize="48" HorizontalAlignment="Center"/>
            <TextBlock Text="Screen Management" FontSize="20" FontWeight="SemiBold"
                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
        </StackPanel>

        <!-- 版本信息 -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,16">
            <TextBlock HorizontalAlignment="Center" FontSize="13"
                       Foreground="{StaticResource SecondaryTextBrush}">
                <Run Text="版本 "/>
                <Run Text="{Binding Version}" FontWeight="SemiBold"/>
            </TextBlock>
            <TextBlock Text="{Binding RuntimeInfo}" FontSize="11"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- 开发者 -->
        <StackPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,0,0,8">
            <TextBlock HorizontalAlignment="Center" FontSize="12">
                <Run Text="开发者: "/>
                <Run Text="{Binding Developer}" FontWeight="SemiBold"/>
            </TextBlock>
        </StackPanel>

        <!-- GitHub -->
        <TextBlock Grid.Row="3" HorizontalAlignment="Center" FontSize="12"
                   Foreground="{StaticResource AccentBrush}"
                   TextDecorations="Underline" Cursor="Hand"
                   MouseLeftButtonUp="GitHubLink_Click">
            <Run Text="{Binding GithubUrl}"/>
        </TextBlock>

        <!-- 版权 -->
        <TextBlock Grid.Row="4" HorizontalAlignment="Center" FontSize="11"
                   Foreground="{StaticResource SecondaryTextBrush}"
                   Text="{Binding Copyright}" Margin="0,12,0,0"/>

        <!-- 关闭按钮 -->
        <Button Grid.Row="6" Content="关闭" Width="80" Height="32"
                HorizontalAlignment="Center"
                Style="{StaticResource PrimaryButtonStyle}"
                Click="CloseButton_Click"/>
    </Grid>
</Window>
